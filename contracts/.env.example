# Mantle Network RPC URLs
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz

# Deployer Wallet Private Key
# WARNING: Never commit this file or expose your private key!
# Use a dedicated deployer wallet with limited funds for testing
PRIVATE_KEY=your_private_key_here

# Mantle Explorer API Key (for contract verification)
# Get your API key from https://explorer.mantle.xyz/api
MANTLE_EXPLORER_API_KEY=your_explorer_api_key_here

# Optional: Gas Reporting
REPORT_GAS=true

# Optional: CoinMarketCap API Key (for gas reporting in USD)
# COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
